# EditorConfig 配置文件
# 确保跨编辑器的编码和格式一致性
# 更多信息: https://editorconfig.org

# 顶级配置文件
root = true

# 所有文件的通用配置
[*]
# 字符编码：UTF-8
charset = utf-8
# 行尾符：LF（Unix格式）
end_of_line = lf
# 文件末尾插入空行
insert_final_newline = true
# 删除行尾空白字符
trim_trailing_whitespace = true

# C/C++源文件配置
[*.{c,h,cpp,hpp}]
charset = utf-8
indent_style = tab
indent_size = 4
tab_width = 4

# Markdown文件配置
[*.md]
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# JSON文件配置
[*.json]
charset = utf-8
indent_style = space
indent_size = 4

# Makefile配置（必须使用Tab）
[Makefile]
charset = utf-8
indent_style = tab

# Python脚本配置
[*.py]
charset = utf-8
indent_style = space
indent_size = 4

# Shell脚本配置
[*.sh]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
